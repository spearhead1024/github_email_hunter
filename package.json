{
  "name": "github-email-hunter",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension that extracts personal emails from GitHub profiles via public commit metadata.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,html,css}\" \"tests/**/*.ts\""
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.0.270",
    "@types/node": "^25.6.0",
    "fake-indexeddb": "^6.2.5",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  },
  "dependencies": {
    "idb": "^8.0.3"
  }
}
